{
  "name": "buglens",
  "displayName": "BugLens",
  "description": "Explains logic bugs without giving away the fix",
  "version": "0.1.0",
  "publisher": "ggttlplp201",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ggttlplp201/BugLens.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "bug",
    "explain",
    "tutor",
    "learning",
    "llm"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "buglens.explain",
        "title": "BugLens: Explain this bug"
      },
      {
        "command": "buglens.setApiKey",
        "title": "BugLens: Set API Key"
      },
      {
        "command": "buglens.clearApiKey",
        "title": "BugLens: Clear API Key"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "buglens.explain",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "BugLens",
      "properties": {
        "buglens.provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic"
          ],
          "default": "openai",
          "description": "LLM provider to use"
        },
        "buglens.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model name (e.g. gpt-4o, claude-sonnet-4-6)"
        },
        "buglens.apiKey": {
          "type": "string",
          "default": "",
          "markdownDeprecationMessage": "**Deprecated:** use the `BugLens: Set API Key` command instead — it stores the key in VS Code secret storage rather than plaintext settings."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "openai": "^6.45.0"
  }
}
